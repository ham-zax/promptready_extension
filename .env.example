# API Keys (Required to enable respective provider)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"       # Required: Format: sk-ant-api03-...
PERPLEXITY_API_KEY="your_perplexity_api_key_here"     # Optional: Format: pplx-...
OPENAI_API_KEY="your_openai_api_key_here"             # Optional, for OpenAI models. Format: sk-proj-...
GOOGLE_API_KEY="your_google_api_key_here"             # Optional, for Google Gemini models.
MISTRAL_API_KEY="your_mistral_key_here"               # Optional, for Mistral AI models.
XAI_API_KEY="YOUR_XAI_KEY_HERE"                       # Optional, for xAI AI models.
GROQ_API_KEY="YOUR_GROQ_KEY_HERE"                     # Optional, for Groq models.
OPENROUTER_API_KEY="YOUR_OPENROUTER_KEY_HERE"         # Optional, for OpenRouter models.
AZURE_OPENAI_API_KEY="your_azure_key_here"            # Optional, for Azure OpenAI models (requires endpoint in .taskmaster/config.json).
OLLAMA_API_KEY="your_ollama_api_key_here"             # Optional: For remote Ollama servers that require authentication.
GITHUB_API_KEY="your_github_api_key_here"             # Optional: For GitHub import/export features. Format: ghp_... or github_pat_...

# PromptReady extension runtime profile overrides (for local extension dev)
WXT_DEV_FORCE_PREMIUM="true"                          # true => bypass free/pro gating in development
WXT_DEV_FORCE_DEVELOPER_MODE="true"                   # true => force developer mode ON in development
WXT_USE_MOCK_MONETIZATION="true"                      # true => skip metered backend calls and use local mock balances
WXT_MONETIZATION_API_BASE="http://127.0.0.1:8788"     # Local wrangler URL for credit/AI proxy worker
WXT_BYOK_PROXY_URL="http://127.0.0.1:8788/byok/proxy" # Local BYOK proxy endpoint to avoid CORS during development
WXT_TRAFILATURA_URL="http://127.0.0.1:8089"            # Optional local Trafilatura fallback service
OPENROUTER_HTTP_REFERER="https://promptready.app"     # Optional app attribution header for OpenRouter requests
OPENROUTER_TITLE="PromptReady Extension"              # Optional app title header for OpenRouter requests
ALLOWED_ORIGINS="https://promptready.app,http://127.0.0.1:5173,http://localhost:5173" # Optional CSV override for proxy CORS allowlist
BYOK_ALLOWED_HOSTNAMES="openrouter.ai"              # Optional CSV allowlist for BYOK upstream hostnames (defaults to openrouter.ai)

# Manual BYOK verification / comparison helpers
BYOK_CHECK_MODEL="arcee-ai/trinity-large-preview:free" # Optional model override for npm run byok:check/byok:compare
BYOK_CHECK_TIMEOUT_MS="20000"                          # Optional timeout (ms) for npm run byok:check
BYOK_COMPARE_OUTPUT_DIR="output/byok-compare"          # Optional output directory for npm run byok:compare artifacts
