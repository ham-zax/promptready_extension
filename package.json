{
  "name": "promptready-extension",
  "description": "AI-powered Chrome extension that instantly cleans and structures webpage content into prompt-ready formats with metered freemium model",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "WXT_RUNTIME_DEVELOPMENT=1 WXT_DEV_OPEN_ACCESS=1 WXT_DEV_FORCE_PREMIUM=1 WXT_DEV_FORCE_DEVELOPER_MODE=1 WXT_USE_MOCK_MONETIZATION=1 wxt",
    "dev:firefox": "WXT_RUNTIME_DEVELOPMENT=1 WXT_DEV_OPEN_ACCESS=1 WXT_DEV_FORCE_PREMIUM=1 WXT_DEV_FORCE_DEVELOPER_MODE=1 WXT_USE_MOCK_MONETIZATION=1 wxt -b firefox",
    "build": "WXT_RUNTIME_DEVELOPMENT=1 WXT_DEV_OPEN_ACCESS=1 WXT_DEV_FORCE_PREMIUM=1 WXT_DEV_FORCE_DEVELOPER_MODE=1 WXT_USE_MOCK_MONETIZATION=1 wxt build",
    "build:firefox": "WXT_RUNTIME_DEVELOPMENT=1 WXT_DEV_OPEN_ACCESS=1 WXT_DEV_FORCE_PREMIUM=1 WXT_DEV_FORCE_DEVELOPER_MODE=1 WXT_USE_MOCK_MONETIZATION=1 wxt build -b firefox",
    "build:prod": "WXT_RUNTIME_DEVELOPMENT=0 wxt build",
    "build:prod:firefox": "WXT_RUNTIME_DEVELOPMENT=0 wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:ui": "vitest",
    "test:smoke": "vitest run tests/hooks.test.tsx tests/ByokSettings.test.tsx tests/offline-processor.test.ts tests/ai-proxy.byok-cors.test.ts tests/runtime-profile.test.ts",
    "test:offline:promptready": "vitest run tests/offline-promptready-iteration.test.ts",
    "test:offline:corpus": "vitest run tests/offline-fixture-regression.test.ts",
    "test:offline:news": "vitest run tests/offline-news-fixture-regression.test.ts",
    "capture:fixture": "bash scripts/capture-fixture.sh",
    "capture:fixtures:core": "bash scripts/capture-core-fixtures.sh",
    "capture:fixtures:news": "bash scripts/capture-news-fixtures.sh",
    "iterate:offline:promptready": "bash scripts/iterate-offline-promptready.sh",
    "iterate:offline:corpus": "bash scripts/iterate-offline-corpus.sh",
    "verify:dev": "npm run compile && npm run test:smoke",
    "verify:dev:retry": "npm run verify:dev && npm run verify:dev",
    "postinstall": "wxt prepare",
    "lint": "npx eslint . --ext .ts,.tsx || true",
    "lint:fix": "npx eslint . --ext .ts,.tsx --fix",
    "format": "npx prettier --write . --ignore-path .git",
    "format:check": "npx prettier --check . --ignore-path .git",
    "prepare": "husky",
    "precommit": "husky add pre-commit --command 'npm run pre-commit-check'",
    "commitlint": "commitlint --edit",
    "pre-commit-check": "bash .husky/pre-commit"
  },
  "dependencies": {
    "@heroicons/react": "^2.1.3",
    "@joplin/turndown": "^4.0.80",
    "@joplin/turndown-plugin-gfm": "^1.0.62",
    "@mozilla/readability": "^0.4.1",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@tailwindcss/vite": "^4.1.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dompurify": "^3.2.6",
    "lucide-react": "^0.539.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250813.0",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "@types/turndown": "^5.0.5",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@wxt-dev/module-react": "^1.1.3",
    "eslint": "^9.39.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "tw-animate-css": "^1.3.6",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.30.0",
    "wxt": "^0.20.6"
  }
}
